# Copy this file to .env and fill in your own values. Never commit .env.
#
# The authorization token is your Discord account/user token. It is the only
# strictly required value. The rest help requests look like a real browser
# session and are optional.

# REQUIRED: Discord authorization token.
DISCORD_AUTHORIZATION=

# OPTIONAL: a single default channel id (used when none is passed explicitly).
DISCORD_CHANNEL_ID=

# OPTIONAL: browser-session cookies. cf_clearance is Cloudflare's anti-bot
# cookie; include it if you hit 403/Cloudflare challenges. It is tied to your
# IP + browser and expires fairly quickly.
DISCORD_COOKIE_DCFDUID=
DISCORD_COOKIE_SDCFDUID=
DISCORD_COOKIE_LOCALE=
DISCORD_COOKIE_CFUVID=
DISCORD_COOKIE_CF_CLEARANCE=

# OPTIONAL: browser fingerprint properties (base64).
DISCORD_X_SUPER_PROPERTIES=
DISCORD_X_CONTEXT_PROPERTIES=

# OPTIONAL: request metadata.
DISCORD_USER_AGENT=
DISCORD_LOCALE=en-US
DISCORD_TIMEZONE=Europe/Paris

# OPTIONAL: cap on how many old messages to backfill per channel (mostly the
# first run). 0 or empty means no cap (fetch the whole channel history).
DISCORD_MAX_OLD_MESSAGES=1000

# OPTIONAL: seconds to wait between sync passes over all channels (default 300 = 5 min).
DISCORD_SYNC_INTERVAL_SECONDS=300

# OPTIONAL: paths and API base.
DISCORD_API_BASE=https://discord.com/api/v9
DISCORD_CHANNELS_FILE=channels.json
DISCORD_CHATLOGS_DIR=chatlogs

# OPTIONAL: Flask server bind settings.
HOST=127.0.0.1
PORT=5000
